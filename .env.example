# Backend provider keys
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_DEFAULT_VOICE_ID=your_default_voice_id

# Optional per-intent ElevenLabs voices
ELEVENLABS_VOICE_ID_QUIET_RESTORATION=your_quiet_restoration_voice_id
ELEVENLABS_VOICE_ID_MILESTONE=your_milestone_voice_id
ELEVENLABS_VOICE_ID_CELEBRATION_DISCOVERY=your_celebration_discovery_voice_id

# Frontend
VITE_API_BASE_URL=http://localhost:8000
